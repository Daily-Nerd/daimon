{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}\"/hook/daimon-session-brief.py",
            "timeout": 10,
            "statusMessage": "Reading daimon briefing..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}\"/hook/daimon-prompt-recall.py",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}\"/hook/daimon-session-end.py",
            "timeout": 10,
            "statusMessage": "Writing daimon checkpoint..."
          }
        ]
      }
    ]
  }
}
